<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <title>体检报告 - {{ patientInfo.name }}</title>
  <style>
{% include "health-report/styles.css" %}
  </style>
</head>
<body>
  <div class="header">
    <h1>健康体检报告</h1>
    <p>Health Examination Report</p>
  </div>

  <div class="patient-info">
    <h2>基本信息</h2>
    <div class="info-grid">
      <div class="info-item">
        <span class="label">姓名：</span>
        <span class="value">{{ patientInfo.name }}</span>
      </div>
      <div class="info-item">
        <span class="label">性别：</span>
        <span class="value">{{ patientInfo.gender }}</span>
      </div>
      <div class="info-item">
        <span class="label">年龄：</span>
        <span class="value">{{ patientInfo.age }} 岁</span>
      </div>
      <div class="info-item">
        <span class="label">身份证：</span>
        <span class="value">{{ patientInfo.idCard }}</span>
      </div>
      <div class="info-item">
        <span class="label">体检日期：</span>
        <span class="value">{{ patientInfo.examDate }}</span>
      </div>
    </div>
  </div>

  {% for category in examItems %}
  <div class="exam-section">
    <h3>{{ category.category }}</h3>
    <table class="exam-table">
      <thead>
        <tr>
          <th style="width: 25%">项目名称</th>
          <th style="width: 20%">检测结果</th>
          <th style="width: 15%">单位</th>
          <th style="width: 25%">参考范围</th>
          <th style="width: 15%">状态</th>
        </tr>
      </thead>
      <tbody>
        {% for item in category.items %}
        <tr>
          <td>{{ item.name }}</td>
          <td>{{ item.value }}</td>
          <td>{{ item.unit }}</td>
          <td>{{ item.reference }}</td>
          <td class="status-{{ item.status }}">
            {% if item.status == 'normal' %}正常
            {% elif item.status == 'high' %}偏高 ↑
            {% else %}偏低 ↓
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endfor %}

  <div class="summary">
    <h2>体检结论与建议</h2>
    <div class="conclusion">
      <strong>总体结论：</strong>{{ summary.conclusion }}
    </div>
    {% if summary.suggestions.length > 0 %}
    <div class="suggestions">
      <h4>健康建议：</h4>
      <ul>
        {% for suggestion in summary.suggestions %}
        <li>{{ suggestion }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
  </div>

  <div class="footer">
    <p>本报告仅供参考，如有疑问请咨询专业医生</p>
    <p>报告生成时间：{{ generatedAt }}</p>
  </div>
</body>
</html>

